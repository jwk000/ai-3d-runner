{
  "name": "ai-3d-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Quad Runner — first-person-ish 3D tunnel runner where the whole tunnel rotates beneath your feet.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --mode pages",
    "preview": "vite preview",
    "preview:pages": "pnpm build:pages && vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
